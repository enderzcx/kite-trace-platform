# Backend signer configuration (server-side custody)
# Never expose this key to frontend/client runtime.

PORT=3001
KITEAI_RPC_URL=https://rpc-testnet.gokite.ai/
KITEAI_BUNDLER_URL=https://bundler-service.staging.gokite.ai/rpc/
KITE_ENTRYPOINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108
KITE_SESSION_PAY_RETRIES=3
KITE_BUNDLER_RPC_TIMEOUT_MS=15000
KITE_BUNDLER_RPC_RETRIES=3
KITE_BUNDLER_RPC_BACKOFF_BASE_MS=650
KITE_BUNDLER_RPC_BACKOFF_MAX_MS=6000
KITE_BUNDLER_RECEIPT_POLL_INTERVAL_MS=3000
KITE_SESSION_PAY_METRICS_RECENT_LIMIT=80
KITE_PROOF_RPC_TIMEOUT_MS=10000
KITE_PROOF_RPC_RETRIES=3
KITE_PROOF_RECEIPT_WAIT_MS=45000
KITE_PROOF_RECEIPT_POLL_INTERVAL_MS=2500
KITECLAW_BACKEND_SIGNER_PRIVATE_KEY=0x_your_test_private_key
# Security default: keep disabled to prevent backend private key relay confirmation.
# Set to 1 only for temporary debugging when bundler/userOp path is unstable.
KITE_ALLOW_EOA_RELAY_FALLBACK=0
# Security default: keep disabled to prevent backend private key signing userOp hash.
KITE_ALLOW_BACKEND_USEROP_SIGN=0

# Persistence backend:
# - file (default): JSON files in backend/data
# - postgres: durable storage in PostgreSQL table app_state_documents
KITE_PERSISTENCE_MODE=file
DATABASE_URL=
KITE_PG_SSL=0
KITE_PG_SSL_REJECT_UNAUTHORIZED=0

# Optional API key roles (enable auth if any key is set)
# - admin: policy/session management
# - agent: workflow/pay/signing
# - viewer: readonly dashboards/evidence
# Set KITECLAW_AUTH_DISABLED=1 to bypass auth checks in local dev.
KITECLAW_AUTH_DISABLED=0
KITECLAW_API_KEY_ADMIN=
KITECLAW_API_KEY_AGENT=
KITECLAW_API_KEY_VIEWER=
KITECLAW_RATE_LIMIT_WINDOW_MS=60000
KITECLAW_RATE_LIMIT_MAX=240

# Identity verify mode:
# - signature (default): visitor wallet must sign challenge and match ERC-8004 agentWallet
# - registry_only: trust registry-bound service identity (better for public demo websites)
IDENTITY_VERIFY_MODE=signature

# LLM adapter (provider-agnostic)
# Leave LLM_BASE_URL empty to use local fallback intent parser.
# Recommended local OpenAI-compatible config:
# LLM_BASE_URL=http://127.0.0.1:11434
# LLM_CHAT_PROTOCOL=openai
# LLM_CHAT_PATH=/v1/chat/completions
# LLM_HEALTH_PATH=/v1/models
# LLM_MODEL=<your_model_id>
# e.g. kimi-coding/k2p5 | qwen2.5-coder | deepseek-chat
LLM_BASE_URL=
LLM_CHAT_PATH=/v1/chat/completions
LLM_HEALTH_PATH=/v1/models
LLM_API_KEY=
LLM_TIMEOUT_MS=12000
LLM_CHAT_PROTOCOL=openai
LLM_MODEL=
# Model routing (optional):
# - AGENT001 uses primary+fallback, worker agents use AGENT_WORKER_MODEL
# - LLM_AGENT_MODELS format: key=model;key=model
# - LLM_AGENT_FALLBACK_MODELS format: key=model1|model2;key=model3
# Example for your target setup:
# AGENT001_MODEL_PRIMARY=qwen3.5:4b
# AGENT001_MODEL_FALLBACK=qwen3.5:2b
# AGENT_WORKER_MODEL=qwen3.5:0.8b
AGENT001_MODEL_PRIMARY=
AGENT001_MODEL_FALLBACK=
AGENT_WORKER_MODEL=
LLM_AGENT_MODELS=
LLM_AGENT_FALLBACK_MODELS=
LLM_MODEL_FALLBACKS=
LLM_SYSTEM_PROMPT=

# Analysis provider:
# built-in market-data (Binance/CoinGecko/Fear&Greed + local indicators)
# Message provider router (primary: opennews, secondary: opentwitter, fallback: market-data)
OPENNEWS_API_BASE=https://ai.6551.io
OPENNEWS_TOKEN=
OPENNEWS_TIMEOUT_MS=8000
OPENNEWS_RETRY=1
OPENNEWS_MAX_ROWS=8
TWITTER_API_BASE=https://ai.6551.io
TWITTER_TOKEN=
TWITTER_TIMEOUT_MS=8000
TWITTER_RETRY=1
TWITTER_MAX_ROWS=8
MESSAGE_PROVIDER_DEFAULT_KEYWORDS=BTC,AI,缇庤偂,ETH
MESSAGE_PROVIDER_DISABLE_CLAWFEED=1
MESSAGE_PROVIDER_MARKET_DATA_FALLBACK=1

# XMTP agent runtime (optional; communication layer for Agent Network demo)
# Enable only after setting wallet key + db encryption key.
XMTP_ENABLED=0
XMTP_ENV=dev
# Optional explicit endpoints (useful for XMTP_ENV=local + xmtpd)
# Example local xmtpd node API: http://127.0.0.1:5050
XMTP_API_URL=
# Set to null to disable history sync endpoint when local stack has no sync service.
XMTP_HISTORY_SYNC_URL=
# Optional gateway host override (normally empty for local/dev).
XMTP_GATEWAY_HOST=
# router runtime signer (preferred)
XMTP_ROUTER_WALLET_KEY=
# fallback signer for router runtime when XMTP_ROUTER_WALLET_KEY is empty
XMTP_WALLET_KEY=
# optional second runtime signer for risk-agent listener
XMTP_RISK_WALLET_KEY=
# optional runtime signer for reader-agent listener
XMTP_READER_WALLET_KEY=
# optional runtime signer for price-agent listener
XMTP_PRICE_WALLET_KEY=
# optional runtime signer for executor-agent listener
XMTP_EXECUTOR_WALLET_KEY=
XMTP_DB_ENCRYPTION_KEY=
XMTP_DB_DIRECTORY=./data/xmtp-db
XMTP_ROUTER_RUNTIME_ENABLED=0
XMTP_RISK_RUNTIME_ENABLED=0
XMTP_READER_RUNTIME_ENABLED=0
XMTP_PRICE_RUNTIME_ENABLED=0
XMTP_EXECUTOR_RUNTIME_ENABLED=0
XMTP_AUTO_ACK=0
XMTP_EVENT_RETENTION=600
XMTP_ROUTER_AGENT_ADDRESS=
XMTP_RISK_AGENT_ADDRESS=
XMTP_READER_AGENT_ADDRESS=
XMTP_PRICE_AGENT_ADDRESS=
XMTP_EXECUTOR_AGENT_ADDRESS=
XMTP_ROUTER_AGENT_AA_ADDRESS=
XMTP_RISK_AGENT_AA_ADDRESS=
XMTP_READER_AGENT_AA_ADDRESS=
XMTP_PRICE_AGENT_AA_ADDRESS=
XMTP_EXECUTOR_AGENT_AA_ADDRESS=
XMTP_RISK_IDENTITY_REGISTRY=
XMTP_RISK_IDENTITY_AGENT_ID=
XMTP_TECHNICAL_IDENTITY_REGISTRY=
XMTP_TECHNICAL_IDENTITY_AGENT_ID=
XMTP_READER_IDENTITY_REGISTRY=
XMTP_READER_IDENTITY_AGENT_ID=
XMTP_MESSAGE_IDENTITY_REGISTRY=
XMTP_MESSAGE_IDENTITY_AGENT_ID=
XMTP_AUTO_NETWORK_ENABLED=0
XMTP_AUTO_NETWORK_INTERVAL_MS=60000
XMTP_AUTO_NETWORK_SOURCE_AGENT_ID=router-agent
XMTP_AUTO_NETWORK_TARGET_AGENT_IDS=risk-agent,reader-agent
XMTP_AUTO_NETWORK_CAPABILITY=network-heartbeat

# Optional x402 config
KITE_SETTLEMENT_TOKEN=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63
KITE_MERCHANT_ADDRESS=0x6D705b93F0Da7DC26e46cB39Decc3baA4fb4dd29
X402_UNIFIED_SERVICE_PRICE=0.00015
X402_PRICE=0.00015
X402_REACTIVE_PRICE=0.00015
X402_BTC_PRICE=0.00015
X402_RISK_SCORE_PRICE=0.00015
X402_TECHNICAL_PRICE=0.00015
X402_X_READER_PRICE=0.00015
X402_INFO_PRICE=0.00015
X402_HYPERLIQUID_ORDER_PRICE=0.00015
X402_HYPERLIQUID_ORDER_RECIPIENT=
KITE_AGENT2_AA_ADDRESS=0xEd335560178B85f0524FfFf3372e9Bf45aB42aC8
KITE_POLICY_MAX_PER_TX=0.20
KITE_POLICY_DAILY_LIMIT=0.60
KITE_POLICY_ALLOWED_RECIPIENTS=0x6D705b93F0Da7DC26e46cB39Decc3baA4fb4dd29,0xEd335560178B85f0524FfFf3372e9Bf45aB42aC8

# AGENT001 trade-plan loop (message + technical, optional)
# default disabled; set to 1 only when you want server boot auto-start
AUTO_TRADE_PLAN_ENABLED=0
AUTO_TRADE_PLAN_INTERVAL_MS=600000
AUTO_TRADE_PLAN_SYMBOL=BTCUSDT
AUTO_TRADE_PLAN_HORIZON_MIN=60
# optional custom prompt; keep empty to use built-in prompt template
AUTO_TRADE_PLAN_PROMPT=

# x-reader digest defaults
X_READER_MAX_CHARS_DEFAULT=1200

# Optional ERC-8004 identity config
# Use your deployed IdentityRegistry on Kite (or another supported chain)
ERC8004_IDENTITY_REGISTRY=0x_your_identity_registry
ERC8004_AGENT_ID=0
ERC8004_TRUST_ANCHOR_REGISTRY=0x_your_trust_anchor_registry
ERC8004_AGENT_URI=https://your-domain/agent.json
ERC8004_AGENT_WALLET=
ERC8004_AGENT_NAME=Kite Trace Agent
ERC8004_AGENT_DESCRIPTION=Kite Trace CLI-first MVP agent identity on Kite testnet
ERC8004_AGENT_CAPABILITIES=negotiated-buy,x402-payment,erc8183-job
ERC8004_AGENT_TRANSPORTS=http,xmtp
ERC8004_REGISTRAR_PRIVATE_KEY=0x_your_test_private_key
ERC8004_IDENTITY_NAME=Kite Trace Identity Registry
ERC8004_IDENTITY_SYMBOL=KTRC
ERC8004_REGISTER_FEE=0
ERC8004_METADATA_UPDATE_FEE=0
ERC8004_DEPLOY_OWNER=

# Optional ktrace CLI defaults
KTRACE_BASE_URL=http://127.0.0.1:3001
KTRACE_CHAIN=kite-testnet
KTRACE_PROFILE=default
KTRACE_OUTPUT=json
KTRACE_TIMEOUT_MS=60000

