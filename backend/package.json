  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nktkas/hyperliquid": "^0.31.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@xmtp/agent-sdk": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^4.19.2",
    "pg": "^8.16.3",
    "solc": "^0.8.34",
    "zod": "^4.3.6"
