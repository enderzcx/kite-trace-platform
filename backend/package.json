    "erc8183:compile:escrow": "node scripts/erc8183-compile-escrow.js",
    "erc8183:compile:escrow:v2": "node scripts/erc8183-compile-escrow-v2.js",
    "erc8183:compile:escrow:v3": "node scripts/erc8183-compile-escrow-v3.js",
    "erc8183:deploy:escrow": "node scripts/erc8183-deploy-escrow.js",
    "erc8183:deploy:escrow:v2": "node scripts/erc8183-deploy-escrow-v2.js",
    "erc8183:deploy:escrow:v3": "node scripts/erc8183-deploy-escrow-v3.js",
    "erc8183:compile:trace-anchor-guard": "node scripts/erc8183-compile-trace-anchor-guard.js",
    "erc8183:deploy:trace-anchor-guard": "node scripts/erc8183-deploy-trace-anchor-guard.js",
    "erc8183:set:trace-guard": "node scripts/erc8183-set-trace-guard.js",
    "verify:trace-anchor:guard": "node .\\scripts\\verify-trace-anchor-guard.mjs",
    "verify:aa:compat": "node .\\scripts\\verify-aa-compat-smoke.mjs",
    "verify:aa:capabilities": "node .\\scripts\\verify-aa-session-capabilities.mjs",
    "verify:erc8183:aa-native": "node .\\scripts\\verify-erc8183-aa-native.mjs",
    "verify:erc8183:official:v3-proof": "node .\\scripts\\verify-official-erc8183-v3-proof.mjs",
    "erc8183:approve:escrow": "node scripts/erc8183-approve-escrow.js",
    "erc8183:compile:official:minimal": "node scripts/erc8183-compile-official-minimal.js",
    "aa:deploy:factory": "node scripts/aa-deploy-factory.js",
    "aa:compile:v3": "node scripts/aa-compile-v3.js",
    "aa:ensure": "node scripts/aa-ensure-account.js",
    "aa:session:router": "node scripts/aa-create-router-session.js",
    "aa:preflight": "node scripts/aa-preflight.js",
    "aa:upgrade": "node scripts/aa-upgrade.js",
    "aa:verify:factory": "node scripts/aa-verify-factory.js",
    "parity:hopledger": "node scripts/parity-hopledger-reference.mjs --rounds 5"
